{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "stabilityDays": 14,
  "prHourlyLimit": 5,
  "extends": [
    "config:recommended"
  ],
  "additionalReviewers": [
    "@manuelmayer-dev"
  ],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": [
        "node",
        "npm"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "dotnet"
      ],
      "groupName": "dotnet",
      "stabilityDays": 0
    },
    {
      "matchManagers": ["git-submodules"],
      "matchDepNames": ["headsetcontrollib"],
      "groupName": "headsetcontrol",
      "stabilityDays": 3
    }
  ]
}
